# Optional safer setup: keep private wallet keys outside Render backend.
# Backend calls your private signer service.

TON_REMOTE_SIGNER_URL=https://your-private-signer-domain
TON_REMOTE_SIGNER_TOKEN=PASTE_THE_SAME_SIGNER_TOKEN_FROM_PRIVATE_SIGNER
TON_AUTO_PAYOUT_ENABLED=true
TON_SIGNER_ENABLED=true
REQUIRE_TON_AUTO_PAYOUT_FOR_1_5M=true

# Keep TONAPI env for scanner/payment watching.
TONAPI_BASE_URL=https://tonapi.io
TONAPI_KEY=KEEP_EXISTING_TONAPI_KEY
